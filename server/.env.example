NODE_ENV=development
PORT=5001

# MongoDB URI — leave blank to use in-memory MongoDB (dev only)
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/devtrack
MONGO_URI=mongodb://localhost:27017/devtrack

# JWT Secrets — change these in production!
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# SMTP (optional — leave blank for dev auto-verify)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@devtrack.app
FROM_NAME=DevTrack

# OpenAI (optional — leave blank for heuristic recommendations)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
